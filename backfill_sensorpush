import requests
import datetime

def backfill_sensorpush(user, password):
    # 1. Get the OAuth Token
    auth_url = "https://api.sensorpush.com/api/v1/oauth/authorize"
    token_resp = requests.post(auth_url, json={"email": user, "password": password})
    token = token_resp.json().get('accesstoken')

    # 2. Define the "Weekend Gap" (From Friday 7pm to Now)
    start_time = "2026-03-20T19:00:00Z" 
    
    # 3. Pull Samples
    data_url = "https://api.sensorpush.com/api/v1/samples"
    headers = {"Authorization": token, "accept": "application/json"}
    params = {"startTime": start_time}
    
    samples = requests.post(data_url, headers=headers, json=params)
    return samples.json()

